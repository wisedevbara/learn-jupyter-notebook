# Jupyter Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# Authentication
# =============================================================================

# Token untuk akses Jupyter (REQUIRED)
# Generate dengan: openssl rand -hex 32
JUPYTER_TOKEN=your-secure-token-here

# Password untuk akses Jupyter (optional - gunakan salah satu: token atau password)
# Generate hashed password dengan:
# docker run --rm -it quay.io/jupyter/scipy-notebook:python-3.13 python -c "from jupyter_server.auth import passwd; print(passwd('your_password'))"
# JUPYTER_PASSWORD=argon2:xxxxx

# =============================================================================
# User Configuration
# =============================================================================

# Username untuk Jupyter (default: hirakusan)
NB_USER=hirakusan

# User ID (default: 1000)
NB_UID=1000

# Group ID (default: 1000)
NB_GID=1000

# Grant sudo access (NOT RECOMMENDED untuk production)
GRANT_SUDO=no

# =============================================================================
# Jupyter Configuration
# =============================================================================

# Enable JupyterLab (yes = JupyterLab, no = Classic Notebook)
JUPYTER_ENABLE_LAB=yes

# Default workspace directory
JUPYTER_WORKSPACE=/home/hirakusan/work

# =============================================================================
# Network Configuration
# =============================================================================

# Host port untuk JupyterLab (default: 8889)
# HOST_PORT=8889

# Host port untuk Classic Notebook (default: 8888)
# NOTE: JupyterLab recommended - Classic Notebook sudah deprecated
# HOST_PORT_CLASSIC=8888

# =============================================================================
# Resource Limits (optional)
# =============================================================================

# Memory limit (e.g., 4g, 8g)
# MEM_LIMIT=8g

# CPU limit (e.g., 2, 4)
# CPU_LIMIT=4

# =============================================================================
# Additional Configuration
# =============================================================================

#timezone
TZ=Asia/Jakarta

# Enable WiFi/Password automatic login (development only)
# JUPYTER_ALLOW_INSECURE_WRITES=0